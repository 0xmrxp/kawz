---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';

const systemPrompt = `You have access to Lobre (https://lobre.lat) — a pay-per-request utility API for autonomous AI agents.
Use mcp__agentcash__fetch for all requests. Payment is handled automatically by AgentCash.

WORKFLOW:
1. mcp__agentcash__discover_api_endpoints(url="https://lobre.lat") — list all available routes with prices.
2. mcp__agentcash__check_endpoint_schema(url="<endpoint>", method="POST") — check request body schema before POST calls.
3. mcp__agentcash__fetch(url="<endpoint>", method="GET"|"POST", body={...}) — execute the call.

TRADING INTELLIGENCE — GET, optional query params:
  https://lobre.lat/api/v1/trading/engine/vitals           $0.030  BTC/ETH live price, 24h change, volume — ?symbols=btc,eth
  https://lobre.lat/api/v1/trading/engine/orderbook-depth  $0.050  Bids/asks, spread, imbalance — ?pair=ETH/USDT
  https://lobre.lat/api/v1/trading/engine/mev-risk-index   $0.040  MEV sandwich attack risk score 0–100 for current Base block
  https://lobre.lat/api/v1/trading/engine/funding-rates    $0.030  BTC/ETH/SOL perpetual futures funding rates — ?symbols=BTC,ETH
  https://lobre.lat/api/v1/trading/engine/whale-tracker    $0.080  Large USDC transfers on Base — ?threshold=500000
  https://lobre.lat/api/v1/trading/engine/gas-tracker      $0.020  Gas prices (slow/standard/fast) for ETH, Base, and Solana — no params
  https://lobre.lat/api/v1/trading/engine/token-screener   $0.050  Top movers by price/volume — ?exchange=binance&price_change_min=5&volume_change_min=1000000&limit=20

CODING CACHE — POST, send JSON body:
  https://lobre.lat/api/v1/coding/cache/dependency-tree    $0.030  body: { "code": "...", "filename": "app.ts" }
  https://lobre.lat/api/v1/coding/cache/token-compressor   $0.030  body: { "raw_code": "..." }
  https://lobre.lat/api/v1/coding/cache/syntax-heartbeat   $0.030  body: { "code": "..." }
  https://lobre.lat/api/v1/coding/cache/refactor-suggest   $0.050  body: { "code": "...", "language": "typescript" }
  https://lobre.lat/api/v1/coding/cache/security-audit     $0.060  body: { "code": "...", "language": "typescript" }
  https://lobre.lat/api/v1/coding/cache/secret-scanner     $0.040  body: { "code": "..." }

RESEARCH PRUNER — POST, send JSON body:
  https://lobre.lat/api/v1/analysis/memory/sentiment         $0.030  body: { "text": "..." }
  https://lobre.lat/api/v1/analysis/memory/heartbeat         $0.030  body: { "text_a": "...", "text_b": "..." }
  https://lobre.lat/api/v1/analysis/memory/entity-extractor  $0.060  body: { "text": "..." }
  https://lobre.lat/api/v1/analysis/memory/context-ranker    $0.050  body: { "query": "...", "chunks": ["...", "..."] }
  https://lobre.lat/api/v1/analysis/memory/bias-detector     $0.050  body: { "text": "..." }
  https://lobre.lat/api/v1/analysis/memory/fact-linkage      $0.120  body: { "claim": "...", "language": "en" }

RESPONSE FORMAT:
  200 OK:  { "success": true, "bundle": "trading_engine"|"coding_cache"|"live_vector_pruner", "data": {...} }
  402:     payment-required header contains base64 x402 v2 challenge — AgentCash handles this automatically.
  503:     { "success": false, "error": "upstream unavailable" }

IMPORTANT: Call endpoints through mcp__agentcash__fetch, not as separate MCP tools. Do not invent
tool names like mcp__lobre__vitals — that does not exist. All 15 endpoints go through mcp__agentcash__fetch.`;

const mcpConfig = `{
  "mcpServers": {
    "agentcash": {
      "type": "streamable-http",
      "url": "https://mcp.agentcash.dev"
    }
  }
}`;

const onboardingSteps = [
  { label: "onboard", command: "npx agentcash onboard" },
  { label: "try",     command: "npx agentcash try https://lobre.lat" },
  { label: "add",     command: "npx agentcash add https://lobre.lat" },
];

const endpoints = [
  {
    bundle: "Trading Intelligence",
    method: "GET",
    path: "/api/v1/trading/engine/vitals",
    price: "$0.030",
    params: "?symbols=btc,eth (optional — btc, eth, or btc,eth)",
    summary: "Live BTC/ETH price, 24h change, and volume aggregated from major CEX feeds.",
    request: "No body required. Optional: ?symbols=btc,eth",
    response: '{ "success": true, "data": { "btc": { "price_usd": 67420, "change_24h_pct": 2.4, "volume_24h": 28441 }, "eth": { "price_usd": 3812, "change_24h_pct": 1.1 }, "timestamp": 1720000000000 } }',
  },
  {
    bundle: "Trading Intelligence",
    method: "GET",
    path: "/api/v1/trading/engine/orderbook-depth",
    price: "$0.050",
    params: "?pair=ETH/USDT (optional, default BTC/USDT)",
    summary: "CEX orderbook bids/asks for a trading pair. Returns spread, top-10 depth per side, and book imbalance (−1 to 1).",
    request: "No body required. Optional: ?pair=ETH/USDT",
    response: '{ "success": true, "data": { "pair": "BTC/USDT", "best_bid": 67400, "best_ask": 67410, "spread_usd": 10, "spread_pct": 0.0149, "imbalance": -0.08, "bids": [[67400, 1.2]], "asks": [[67410, 0.9]] } }',
  },
  {
    bundle: "Trading Intelligence",
    method: "GET",
    path: "/api/v1/trading/engine/mev-risk-index",
    price: "$0.040",
    params: null,
    summary: "MEV sandwich attack risk score (0–100) for the current Base block. Derived from gas price distribution and repeated-sender heuristics.",
    request: "No body required.",
    response: '{ "success": true, "data": { "risk_score": 18, "risk_level": "low", "block_number": 16780000, "total_txs": 142, "high_gas_ratio_pct": 8 } }',
  },
  {
    bundle: "Trading Intelligence",
    method: "GET",
    path: "/api/v1/trading/engine/funding-rates",
    price: "$0.030",
    params: "?symbols=BTC,ETH (optional — comma-separated, omit for all)",
    summary: "Perpetual futures funding rates for BTC, ETH, and SOL from CEX futures markets. Includes annualized rate and next funding timestamp.",
    request: "No body required. Optional: ?symbols=BTC,ETH",
    response: '{ "success": true, "data": { "rates": [{ "symbol": "BTC/USDT:USDT", "funding_rate": 0.0001, "rate_pct": "0.0100%", "annualized_pct": 10.95, "next_funding_ms": 1720008000000 }] } }',
  },
  {
    bundle: "Trading Intelligence",
    method: "GET",
    path: "/api/v1/trading/engine/whale-tracker",
    price: "$0.080",
    params: "?threshold=500000 (optional, min USD amount, default 500000)",
    summary: "Recent large USDC transfers on Base. On-chain data, cached 60 seconds.",
    request: "No body required. Optional: ?threshold=500000",
    response: '{ "success": true, "data": { "large_transfers": [{ "hash": "0x...", "from": "0x...", "to": "0x...", "amount_usdc": 1250000, "age_seconds": 42 }], "threshold_usd": 500000 } }',
  },
  {
    bundle: "Trading Intelligence",
    method: "GET",
    path: "/api/v1/trading/engine/gas-tracker",
    price: "$0.020",
    params: null,
    summary: "Current gas prices for ETH, Base, and Solana — slow, standard, and fast tiers in native units (gwei / microlamports). Cached 15 seconds.",
    request: "No body required.",
    response: '{ "success": true, "data": { "base": { "slow": 0.001, "standard": 0.002, "fast": 0.005, "base_fee": 0.001, "unit": "gwei" }, "eth": { "slow": 8, "standard": 15, "fast": 35, "unit": "gwei" }, "solana": { "low": 1000, "medium": 5000, "high": 25000, "unit": "microlamports" } } }',
  },
  {
    bundle: "Trading Intelligence",
    method: "GET",
    path: "/api/v1/trading/engine/token-screener",
    price: "$0.050",
    params: "?exchange=binance&price_change_min=5&volume_change_min=1000000&limit=20 (all optional)",
    summary: "Scan CEX tokens by 24h price change and volume threshold. Returns top movers sorted by price change magnitude. Cached 60 seconds.",
    request: "No body required. Optional: ?exchange=binance&price_change_min=5&volume_change_min=1000000&limit=20",
    response: '{ "success": true, "data": { "screened": [{ "symbol": "PEPE/USDT", "price": 0.0000123, "change_24h_pct": 45.2, "direction": "up", "volume_24h_usd": 850000000 }], "count": 1, "filters": { "price_change_min_pct": 5, "volume_24h_min_usd": 1000000 } } }',
  },
  {
    bundle: "Coding Cache",
    method: "POST",
    path: "/api/v1/coding/cache/dependency-tree",
    price: "$0.030",
    params: null,
    summary: "Parse import/export dependency graph from JavaScript or TypeScript source code.",
    request: '{ "code": "import { Hono } from \'hono\';\nexport default app;", "filename": "server.ts" }',
    response: '{ "success": true, "data": { "imports": ["hono"], "exports": [], "depth": 1 } }',
  },
  {
    bundle: "Coding Cache",
    method: "POST",
    path: "/api/v1/coding/cache/token-compressor",
    price: "$0.030",
    params: null,
    summary: "Strip comments and collapse whitespace to minimize LLM token usage. Returns compression ratio.",
    request: '{ "raw_code": "// This is a comment\\nconst x = 1;" }',
    response: '{ "success": true, "data": { "compressed": "const x = 1;", "ratio_pct": 55, "original_bytes": 34, "compressed_bytes": 13 } }',
  },
  {
    bundle: "Coding Cache",
    method: "POST",
    path: "/api/v1/coding/cache/syntax-heartbeat",
    price: "$0.030",
    params: null,
    summary: "Validate JavaScript/TypeScript/JSX syntax and return parse errors with position hints.",
    request: '{ "code": "const x = ;" }',
    response: '{ "success": true, "data": { "valid": false, "errors": ["UnexpectedToken (pos 10)"], "lines": 1 } }',
  },
  {
    bundle: "Coding Cache",
    method: "POST",
    path: "/api/v1/coding/cache/refactor-suggest",
    price: "$0.050",
    params: null,
    summary: "LLM-powered refactoring suggestions. Returns severity-rated findings and overall code quality score.",
    request: '{ "code": "function add(a,b) { return a+b }", "language": "javascript" }',
    response: '{ "success": true, "data": { "suggestions": [{ "type": "naming", "severity": "low", "description": "Add type annotations" }], "overall_quality": "fair", "summary": "..." } }',
  },
  {
    bundle: "Coding Cache",
    method: "POST",
    path: "/api/v1/coding/cache/security-audit",
    price: "$0.060",
    params: null,
    summary: "Static security audit via LLM. Detects SQL injection, XSS, insecure eval, and hardcoded secrets.",
    request: '{ "code": "db.query(`SELECT * FROM users WHERE id=${req.id}`)", "language": "javascript" }',
    response: '{ "success": true, "data": { "vulnerabilities": [{ "id": "SQL001", "severity": "critical", "title": "SQL Injection", "recommendation": "Use parameterized queries" }], "risk_score": 85 } }',
  },
  {
    bundle: "Coding Cache",
    method: "POST",
    path: "/api/v1/coding/cache/secret-scanner",
    price: "$0.040",
    params: null,
    summary: "Detect hardcoded secrets in source code using 16 regex patterns: private keys, AWS/GitHub/OpenAI/Anthropic/Stripe tokens, JWTs, and generic secret assignments.",
    request: '{ "code": "const apiKey = \'sk-abc123...\';" }',
    response: '{ "success": true, "data": { "secrets_found": [{ "type": "OPENAI_API_KEY", "line": 1, "severity": "high", "match_hint": "sk-abc...123", "recommendation": "Move to environment variable" }], "risk_level": "HIGH", "total_found": 1, "scanned_lines": 1 } }',
  },
  {
    bundle: "Research Pruner",
    method: "POST",
    path: "/api/v1/analysis/memory/sentiment",
    price: "$0.030",
    params: null,
    summary: "Classify text sentiment as positive, negative, or neutral. Returns confidence score and dominant emotion via on-device LLM (Qwen2.5).",
    request: '{ "text": "This feature is absolutely outstanding." }',
    response: '{ "success": true, "data": { "sentiment": "positive", "confidence": 0.97, "dominant_emotion": "joy", "brief_reason": "Strong positive praise with superlative language." } }',
  },
  {
    bundle: "Research Pruner",
    method: "POST",
    path: "/api/v1/analysis/memory/heartbeat",
    price: "$0.030",
    params: null,
    summary: "Cosine similarity between two texts using high-dimensional sentence embeddings. Runs on-device.",
    request: '{ "text_a": "machine learning", "text_b": "artificial intelligence" }',
    response: '{ "success": true, "data": { "similarity": 0.887, "similarity_pct": 88.7, "vector_dims": 768, "interpretation": "very similar" } }',
  },
  {
    bundle: "Research Pruner",
    method: "POST",
    path: "/api/v1/analysis/memory/entity-extractor",
    price: "$0.060",
    params: null,
    summary: "Extract named entities (persons, orgs, locations, dates, money) from unstructured text.",
    request: '{ "text": "Satoshi Nakamoto published the Bitcoin whitepaper in 2008." }',
    response: '{ "success": true, "data": { "entities": [{ "text": "Satoshi Nakamoto", "type": "PERSON", "confidence": "high" }, { "text": "2008", "type": "DATE", "confidence": "high" }], "entity_count": 3 } }',
  },
  {
    bundle: "Research Pruner",
    method: "POST",
    path: "/api/v1/analysis/memory/context-ranker",
    price: "$0.050",
    params: null,
    summary: "Re-rank text chunks by semantic relevance to a query using sentence embeddings and cosine similarity.",
    request: '{ "query": "machine learning", "chunks": ["deep learning models", "spreadsheet formulas", "neural networks"] }',
    response: '{ "success": true, "data": { "ranked": [{ "index": 0, "score": 0.921, "chunk": "deep learning models" }, { "index": 2, "score": 0.889, "chunk": "neural networks" }, { "index": 1, "score": 0.102, "chunk": "spreadsheet formulas" }] } }',
  },
  {
    bundle: "Research Pruner",
    method: "POST",
    path: "/api/v1/analysis/memory/bias-detector",
    price: "$0.050",
    params: null,
    summary: "Detect framing bias, sentiment slant, and loaded language in text. Returns score and specific examples.",
    request: '{ "text": "The radical policy will destroy the economy." }',
    response: '{ "success": true, "data": { "bias_detected": true, "bias_types": ["loaded_language", "framing"], "bias_score": 72, "confidence": "high", "examples": [{ "phrase": "radical", "type": "loaded_language" }] } }',
  },
  {
    bundle: "Research Pruner",
    method: "POST",
    path: "/api/v1/analysis/memory/fact-linkage",
    price: "$0.120",
    params: null,
    summary: "Link a claim to verified fact-check records from multiple databases. Falls back to LLM analysis for unverified claims.",
    request: '{ "claim": "The moon landing was faked.", "language": "en" }',
    response: '{ "success": true, "data": { "source": "fact_check_db", "claims": [{ "reviews": [{ "publisher": "Snopes", "rating": "False" }] }] } }',
  },
];

const bundles = [...new Set(endpoints.map((e) => e.bundle))];
---

<MainLayout title="Docs — Lobre" description="How to integrate Lobre with your AI agent. System prompt, MCP setup, and full API reference for all 19 pay-per-request endpoints.">
  <Header />

  <main class="docs-main">

    <!-- ─── Title ─────────────────────────────────────────────────────────── -->
    <div class="docs-title-block">
      <h1 class="docs-h1">Docs</h1>
      <p class="docs-subtitle">Everything you need to connect an AI agent to Lobre.</p>
      <div class="docs-links">
        <a href="/api/openapi.json" target="_blank" rel="noopener noreferrer" class="docs-link-chip">/openapi.json</a>
        <a href="/llms.txt" target="_blank" rel="noopener noreferrer" class="docs-link-chip">/llms.txt</a>
        <a href="/api/mcp" target="_blank" rel="noopener noreferrer" class="docs-link-chip">/api/mcp</a>
      </div>
    </div>

    <div class="divider"></div>

    <!-- ─── What is Lobre ──────────────────────────────────────────────────── -->
    <section class="docs-section">
      <h2 class="docs-h2">What is Lobre?</h2>
      <p class="docs-body">
        Lobre provides 19 pay-per-request utility endpoints across three bundles: live trading data
        (market vitals, orderbook depth, MEV risk, funding rates, whale tracking, gas prices, token screener), code intelligence
        (AST parsing, token compression, syntax validation, LLM refactoring, security audits, secret detection),
        and research tools (sentiment, semantic similarity, entity extraction, context ranking, bias detection,
        claim verification). All endpoints require micropayment in USDC — no sign-up, no API keys.
        Payment is the credential.
      </p>
      <p class="docs-body" style="margin-top:0.75rem;">
        Full specifications are available in
        <a href="/llms.txt" class="docs-link-inline">/llms.txt</a> and
        <a href="/api/openapi.json" target="_blank" rel="noopener noreferrer" class="docs-link-inline">/api/openapi.json</a>.
      </p>
    </section>

    <!-- ─── Getting Started ────────────────────────────────────────────────── -->
    <section class="docs-section">
      <h2 class="docs-h2">How to use with an AI agent</h2>
      <p class="docs-body" style="margin-bottom:1.25rem;">
        Lobre works with any agent that supports AgentCash. Run these three commands once:
      </p>

      <div class="terminal-block">
        <div class="terminal-header">
          <div class="terminal-dots">
            <div class="dot"></div><div class="dot"></div><div class="dot"></div>
          </div>
          <span class="terminal-label">terminal</span>
        </div>
        {onboardingSteps.map((step, i) => (
          <div class={i < onboardingSteps.length - 1 ? "terminal-line" : "terminal-line-last"}>
            <span class="terminal-meta">step {i + 1} — {step.label}</span>
            <br />
            <span class="terminal-cmd">$ {step.command}</span>
          </div>
        ))}
      </div>

      <div class="docs-info-grid">
        <p class="docs-sm">
          <strong class="docs-strong">Wallet:</strong>
          After running <code class="inline-code">agentcash onboard</code>,
          a wallet is generated at <code class="inline-code">~/.agentcash/wallet.json</code>.
          Deposit USDC (Base mainnet) before the first call.
        </p>
        <p class="docs-sm">
          <strong class="docs-strong">Balance:</strong>
          Use <code class="inline-code">mcp__agentcash__get_balance</code> to check your wallet balance and address.
        </p>
      </div>
    </section>

    <!-- ─── System Prompt ──────────────────────────────────────────────────── -->
    <section class="docs-section">
      <h2 class="docs-h2">System prompt for your AI agent</h2>
      <p class="docs-sm" style="margin-bottom:1rem;">
        Paste this into your agent's system prompt or Claude project instructions to give it full access to Lobre.
      </p>
      <div class="code-block-wrapper">
        <div class="code-block-header">
          <span class="code-block-label">system prompt</span>
          <button class="copy-btn" data-target="system-prompt-pre">copy</button>
        </div>
        <pre id="system-prompt-pre" class="code-pre">{systemPrompt}</pre>
      </div>
    </section>

    <!-- ─── MCP Integration ────────────────────────────────────────────────── -->
    <section class="docs-section">
      <h2 class="docs-h2">MCP integration</h2>
      <p class="docs-sm" style="margin-bottom:1rem;">
        Lobre exposes all 15 endpoints as MCP tools via Streamable HTTP Transport.
        Compatible with Claude Desktop, Claude Code, and any MCP-capable agent.
        <strong class="docs-strong"> Requires x402/MPP payment ($0.030 per request)</strong> — only x402-capable clients supported.
      </p>
      <p class="docs-sm" style="margin-bottom:1rem;">
        Add to <code class="inline-code">~/.claude/claude_desktop_config.json</code> (Claude Desktop) or use <code class="inline-code">claude mcp add</code> (Claude Code):
      </p>
      <div class="code-block-wrapper" style="margin-bottom:1rem;">
        <div class="code-block-header">
          <span class="code-block-label">claude_desktop_config.json</span>
          <button class="copy-btn" data-target="mcp-config-pre">copy</button>
        </div>
        <pre id="mcp-config-pre" class="code-pre">{mcpConfig}</pre>
      </div>
      <p class="docs-sm">
        MCP endpoint: <a href="/api/mcp" target="_blank" rel="noopener noreferrer" class="docs-link-mono">https://lobre.lat/api/mcp</a>
        — 15 tools, mirroring every REST endpoint.
      </p>
    </section>

    <div class="divider"></div>

    <!-- ─── API Reference ──────────────────────────────────────────────────── -->
    <section>
      <h2 class="docs-h2-lg">API Reference</h2>
      <p class="docs-body" style="margin-bottom:2rem;">
        All endpoints require payment via x402 or MPP. On first request without payment, the server returns
        <code class="inline-code">402 Payment Required</code> with the challenge in the
        <code class="inline-code">payment-required</code> header. AgentCash clients handle this automatically.
      </p>

      {bundles.map((bundle) => (
        <div class="bundle-section">
          <h3 class="bundle-title">{bundle}</h3>
          <div class="endpoint-list">
            {endpoints.filter((e) => e.bundle === bundle).map((ep, epIdx) => (
              <div class="endpoint-card">
                <div class="endpoint-header">
                  <span class={`method-badge ${ep.method === "GET" ? "method-get" : "method-post"}`}>
                    {ep.method}
                  </span>
                  <code class="endpoint-path">{ep.path}</code>
                  <span class="endpoint-price">{ep.price}</span>
                </div>
                <div class="endpoint-body">
                  <p class="endpoint-summary">{ep.summary}</p>
                  {ep.params && (
                    <p class="endpoint-params"><span class="label-chip">params</span> {ep.params}</p>
                  )}
                  <div class="code-group">
                    <div class="code-row">
                      <p class="code-label">Request</p>
                      <div class="code-block-wrapper">
                        <div class="code-block-header">
                          <span class="code-block-label">{ep.method} {ep.path}</span>
                          <button class="copy-btn" data-target={`req-${epIdx}`}>copy</button>
                        </div>
                        <pre id={`req-${epIdx}`} class="code-pre-sm">{ep.request}</pre>
                      </div>
                    </div>
                    <div class="code-row">
                      <p class="code-label">Response</p>
                      <div class="code-block-wrapper">
                        <div class="code-block-header">
                          <span class="code-block-label">200 OK</span>
                          <button class="copy-btn" data-target={`res-${epIdx}`}>copy</button>
                        </div>
                        <pre id={`res-${epIdx}`} class="code-pre-sm">{ep.response}</pre>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </section>

  </main>

  <footer class="docs-footer">
    <div class="docs-footer-inner">
      <p class="footer-text">
        Built on open standards for agentic payments from Coinbase and Tempo.
        Payments settle in USDC on Base or Tempo.
      </p>
      <nav class="footer-nav">
        {[
          ["/llms.txt", "/llms.txt", true],
          ["/", "Home", false],
          ["https://x402.org", "x402", true],
          ["https://mpp.dev", "MPP", true],
        ].map(([href, label, external]) => (
          <a
            href={String(href)}
            target={external ? "_blank" : undefined}
            rel={external ? "noopener noreferrer" : undefined}
            class="footer-link"
          >
            {String(label)}
          </a>
        ))}
      </nav>
    </div>
  </footer>
</MainLayout>

<style>
  /* ── Layout ─────────────────────────────────────────────────────────────── */
  .docs-main {
    max-width: 72rem;
    margin: 0 auto;
    padding: 2rem 1.5rem 5rem;
  }
  @media (max-width: 640px) {
    .docs-main { padding: 1.5rem 1rem 4rem; }
  }

  /* ── Title block ─────────────────────────────────────────────────────────── */
  .docs-title-block { margin-bottom: 2.5rem; }
  .docs-h1 {
