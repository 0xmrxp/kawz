---
export interface Props {
  steps: { label: string; command: string }[];
}
const { steps } = Astro.props;
---

<div style="background:#282D37;border:2px solid #374151;box-shadow:4px 4px 0 0 #374151;padding:1.5rem;">
  <!-- Fake terminal title bar -->
  <div style="display:flex;gap:0.5rem;margin-bottom:1rem;align-items:center;">
    <div style="width:0.6rem;height:0.6rem;border-radius:50%;background:#374151;"></div>
    <div style="width:0.6rem;height:0.6rem;border-radius:50%;background:#374151;"></div>
    <div style="width:0.6rem;height:0.6rem;border-radius:50%;background:#374151;"></div>
    <span style="margin-left:0.5rem;font-size:0.75rem;color:#9CA3AF;font-family:'JetBrains Mono',monospace;">lobre.lat</span>
  </div>

  {steps.map((step, i) => (
    <div style={i < steps.length - 1 ? "margin-bottom:0.75rem;" : ""}>
      <span style="color:#9CA3AF;font-family:'JetBrains Mono',monospace;font-size:0.875rem;">
        step {i + 1} — {step.label}
      </span>
      <br />
      <span style="color:#D4AF37;font-family:'JetBrains Mono',monospace;font-size:0.875rem;">
        $ {step.command}
      </span>
    </div>
  ))}
</div>
