---
const nav = [
  { label: "Docs",    href: "/docs" },
  { label: "llms.txt", href: "/llms.txt", external: true },
  { label: "OpenAPI", href: "/api/openapi.json", external: true },
];
---

<header style="border-bottom:2px solid #374151;padding:0 1.5rem;">
  <div style="max-width:72rem;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:3.5rem;">
    <!-- Logo -->
    <a href="/" style="font-weight:700;font-size:1.25rem;letter-spacing:-0.02em;color:#D4AF37;text-decoration:none;">
      LOBRE
    </a>

    <!-- Nav -->
    <nav style="display:flex;gap:1.5rem;align-items:center;">
      {nav.map((item) => (
        <a
          href={item.href}
          target={item.external ? "_blank" : undefined}
          rel={item.external ? "noopener noreferrer" : undefined}
          style="font-size:0.875rem;color:#9CA3AF;text-decoration:none;font-family:'JetBrains Mono',monospace;"
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
