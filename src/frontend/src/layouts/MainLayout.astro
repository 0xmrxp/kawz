---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Lobre — Agentic Infrastructure Engine",
  description = "Pay-per-request utility infrastructure for autonomous AI agents. 15 endpoints across trading, coding, and research. No sign-ups.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body style="background:#1E2229;color:#F3F4F6;font-family:'Space Grotesk',system-ui,sans-serif;">
    <slot />
  </body>
</html>
