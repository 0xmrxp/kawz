# ─────────────────────────────────────────
# Lobre — Environment Variables Template
# Copy this file to .env and fill in values.
# NEVER commit .env to git.
# ─────────────────────────────────────────

# App
ENVIRONMENT=production
BASE_URL=https://lobre.lat
PORT=3000

# Redis  (docker-compose spins this up on localhost:6379)
REDIS_URL=redis://localhost:6379

# Ollama  (self-hosted LLM — primary for 5 LLM endpoints)
# Install:    curl -fsSL https://ollama.com/install.sh | sh
# Pull model: ollama pull qwen2.5:3b
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:3b

# Groq API  →  console.groq.com  (cloud fallback if Ollama is down)
GROQ_API_KEY=

# Qdrant  (docker-compose spins this up on localhost:6333)
QDRANT_URL=http://localhost:6333

# x402 / CDP Facilitator  →  portal.cdp.coinbase.com
# Leave empty in development — testnet facilitator (x402.org) is used automatically
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# MPP / Tempo
EVM_PAYEE_ADDRESS=0x0000000000000000000000000000000000000000
MPP_OPERATOR_KEY=
MPP_FEE_PAYER_KEY=
# Generate with: openssl rand -hex 32   — NEVER rotate after go-live
MPP_SECRET_KEY=
# Tempo pathUSD contract address (Tempo mainnet chainId 4217)
# This is NOT Base USDC — Tempo uses its own pathUSD stablecoin (0x20c000...)
# Verify current address at mpp.dev/payment-methods/tempo before prod deploy
MPP_TEMPO_USDC_ADDRESS=0x20c0000000000000000000000000000000000000

# On-chain data sources — public defaults work for MVP, override if needed
# Blockscout Base (free, open-source, replaces deprecated Basescan V1)
BLOCKSCOUT_BASE_URL=https://base.blockscout.com
# Base mainnet public RPC (free, no key needed)
BASE_RPC_URL=https://mainnet.base.org

# Google Fact Check Tools API (free, create key at console.cloud.google.com/apis)
# Optional — fact-linkage falls back to Groq LLM if not configured
GOOGLE_FACTCHECK_API_KEY=

# Payment testing
# Set to "true" to enable payment gates in dev mode without ENVIRONMENT=production
FORCE_PAYMENT=
