# ─────────────────────────────────────────
# Lobre — Environment Variables Template
# Copy this file to .env and fill in values.
# NEVER commit .env to git.
# ─────────────────────────────────────────

# App
ENVIRONMENT=production
BASE_URL=https://lobre.lat
PORT=3000

# Redis  (docker-compose spins this up on localhost:6379)
REDIS_URL=redis://localhost:6379

# Groq API  →  console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Qdrant  (docker-compose spins this up on localhost:6333)
QDRANT_URL=http://localhost:6333

# x402 / CDP Facilitator  →  portal.cdp.coinbase.com
# Leave empty in development — testnet facilitator (x402.org) is used automatically
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# MPP / Tempo
EVM_PAYEE_ADDRESS=0x0000000000000000000000000000000000000000
MPP_OPERATOR_KEY=
MPP_FEE_PAYER_KEY=
# Generate with: openssl rand -hex 32   — NEVER rotate after go-live
MPP_SECRET_KEY=
# Confirmed USDC contract on Base mainnet (verify at mpp.dev/docs before prod deploy)
MPP_TEMPO_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# On-chain data sources — public defaults work for MVP, override if needed
# Blockscout Base (free, open-source, replaces deprecated Basescan V1)
BLOCKSCOUT_BASE_URL=https://base.blockscout.com
# Base mainnet public RPC (free, no key needed)
BASE_RPC_URL=https://mainnet.base.org

# Payment testing
# Set to "true" to enable payment gates in dev mode without ENVIRONMENT=production
FORCE_PAYMENT=
