lobre.lat {
	# OpenAPI spec — proxied to backend so x402scan/mppscan can discover endpoints
	handle /openapi.json {
		rewrite * /api/openapi.json
		reverse_proxy localhost:3000
	}

	# x402 discovery manifest — must be proxied to backend (serves CDP production facilitator).
	# Without this, Caddy serves the static file from dist/ which has the testnet facilitator.
	handle /.well-known/* {
		reverse_proxy localhost:3000
	}

	# API backend — Bun server on port 3000
	handle /api/* {
		reverse_proxy localhost:3000
	}

	# Frontend static files — Astro build output
	handle {
		root * /opt/lobre/src/frontend/dist
		file_server
		try_files {path} {path}/index.html /index.html
	}
}

www.lobre.lat {
	redir https://lobre.lat{uri} permanent
}
